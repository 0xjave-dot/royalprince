{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A women's fashion catalog item in Fab Ruby boutiques",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "sizes": { "type": "array" },
        "colors": { "type": "array" },
        "mainImage": { "type": "string" },
        "hoverImage": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array" }
      },
      "required": ["name", "price", "description", "sizes", "mainImage", "hoverImage", "category"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Customer metadata and rewards points inside Fab Ruby",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "savedAddresses": { "type": "array" },
        "wishlist": { "type": "array" }
      },
      "required": ["uid", "loyaltyPoints"]
    },
    "Order": {
      "title": "Order",
      "description": "An ecommerce purchase records tracking paystack context",
      "type": "object",
      "properties": {
        "reference": { "type": "string" },
        "subtotal": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "total": { "type": "number" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "deliveryState": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["reference", "total", "customerEmail"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Inventory product collection mapped in the store"
    },
    "users": {
      "schema": "UserProfile",
      "description": "User profiles including reward systems"
    },
    "orders": {
      "schema": "Order",
      "description": "Paid and pending checkout orders"
    }
  }
}
