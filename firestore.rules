rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Users can only read and write their own profile document. Admins can read to power analytics.
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Lightweight visit analytics collected from the storefront.
    match /analyticsVisits/{visitId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Shared catalog collections are publicly readable, but only admins can write.
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /vouchers/{voucherCode} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /colorOfTheDay/{slotId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // All other documents are denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
